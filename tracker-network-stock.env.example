DISCORD_BOT_TOKEN=replace-me

# Logging: set a file path to persist logs to disk (rotating, 5 MB x 5 files).
# Leave blank to log to stdout only.
STOCK_BOT_LOG_FILE=logs/stock-bot.log
STOCK_BOT_LOG_LEVEL=INFO
DISCORD_CHANNEL_ID=123456789012345678
DISCORD_MOBILE_PUSH_ENABLED=true
DISCORD_ALERT_MENTION=
POLL_LOOP_MIN_SLEEP_SECONDS=1
POLL_LOOP_MAX_SLEEP_SECONDS=10

# Optional SMS alerts via Twilio REST API.
SMS_ENABLED=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_TO_NUMBERS=
SMS_TIMEOUT_SECONDS=10

# Guarded checkout. Keep disabled until browser profile is logged into retailer.
CHECKOUT_ENABLED=false
CHECKOUT_MODE=review_only
CHECKOUT_HEADLESS=true
CHECKOUT_BROWSER_PROFILE_DIR=/data/playwright-profile
CHECKOUT_ALLOWED_APPROVERS=
CHECKOUT_REQUIRE_ALLOWED_APPROVERS=true
CHECKOUT_MAX_ORDER_TOTAL=
CHECKOUT_REQUIRE_PRICE_MATCH=true
CHECKOUT_DEFAULT_QUANTITY=1
CHECKOUT_DEFAULT_MAX_QUANTITY=1
CHECKOUT_DEFAULT_COOLDOWN_HOURS=24
CHECKOUT_TEST_TIMEOUT_SECONDS=90

# Optional Discord cleanup. Deletes old bot messages; user commands need Manage Messages permission.
MESSAGE_CLEANUP_ENABLED=false
MESSAGE_CLEANUP_TTL_MINUTES=60
MESSAGE_CLEANUP_INTERVAL_MINUTES=10
MESSAGE_CLEANUP_SCAN_LIMIT=200
MESSAGE_CLEANUP_MAX_DELETES_PER_RUN=25
MESSAGE_CLEANUP_DELETE_DELAY_SECONDS=1.25
MESSAGE_CLEANUP_DELETE_USER_COMMANDS=false